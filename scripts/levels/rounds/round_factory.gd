class_name RoundFactory
extends RefCounted

class SpawnerDef:
	var count: int
	var length: float
	var start: float
	
	func _init(p_count: int, p_length: float, p_start: float):
		count = p_count
		length = p_length
		start = p_start

class BloonDef:
	var type: int
	var camo: bool
	var regen: bool
	
	func _init(p_type: int, p_camo: bool, p_regen: bool):
		type = p_type
		camo = p_camo
		regen = p_regen

class GroupDef:
	var bloon: BloonDef
	var spawners: Array[SpawnerDef]
	
	func _init():
		spawners = []

class RoundDef:
	var flavor_text: String
	var groups: Array[GroupDef]
	
	func _init():
		groups = []
